# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# supabase cli cache (auto-managed)
supabase/.temp/

# scratch
/tmp/

# real tenant configs may contain admin passwords — never commit
# (the *.example.json template stays tracked). Belt-and-braces:
# README recommends putting real configs outside the repo (e.g. /tmp/).
scripts/*-config.*.json
!scripts/*-config.example.json
